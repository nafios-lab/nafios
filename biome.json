{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "ignoreUnknown": true,
    "includes": ["**", "!**/dist", "!**/node_modules", "!**/*.gen.*"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "useFilenamingConvention": {
          "level": "error",
          "options": {
            "filenameCases": ["kebab-case"]
          }
        },
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "patterns": [
              {
                "group": ["@nafios/*/internal/*"],
                "message": "Do not import from another package's internal/ directory. Use the public barrel (@nafios/<name>) instead."
              }
            ]
          }
        }
      }
    }
  },
  "css": {
    "parser": {
      "cssModules": false
    },
    "linter": {
      "enabled": true
    }
  },
  "overrides": [
    {
      "includes": ["packages/finance/src/domain/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "**/internal/**",
                      "**/internal",
                      "@nafios/database",
                      "@nafios/supabase-core",
                      "@supabase/*"
                    ],
                    "message": "src/domain/ is the pure layer — it must not import the data layer (src/internal/), @nafios/database, @nafios/supabase-core, or @supabase/*. Move I/O to src/internal/."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["packages/ui/src/styles/**/*.css"],
      "css": {
        "parser": {
          "tailwindDirectives": true
        }
      }
    },
    {
      "includes": ["apps/docs/content/.vitepress/theme/**/*.css"],
      "linter": {
        "rules": {
          "complexity": {
            "noImportantStyles": "off"
          }
        }
      }
    }
  ],
  "assist": {
    "enabled": true,
    "actions": { "source": { "organizeImports": "on" } }
  }
}
