# NafiOS — Local Environment Variables
#
# Copy this file to .env and fill in values from `bunx supabase status`.
# Local demo keys are NOT secrets — they are deterministic and printed by the CLI.
# Cloud keys ARE secrets and must never be committed.
#
# See: specs/data/supabase-local-stack.md for full documentation.

# Supabase API (PostgREST)
SUPABASE_URL=http://127.0.0.1:54321

# Anon key — used by client-side code; respects RLS policies.
# Get from: bunx supabase status → anon key
SUPABASE_ANON_KEY=

# Service-role key — bypasses RLS; server-side only.
# Get from: bunx supabase status → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection — used by migrations, tests, and raw SQL.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
