# NafiOS — Environment Variables (Supabase Cloud: nafios-staging)
#
# Copy this file to .env and fill in values from the Supabase dashboard.
# Local Docker is sunset — we target the hosted `nafios-staging` project.
# These keys ARE secrets. Never commit .env (it is gitignored).
#
# See: specs/data/supabase-local-stack.md and supabase/README.md for the
# full CLI workflow (login, link, migrate, gen types).

# Supabase API URL — Dashboard → Project Settings → API → Project URL
# Format: https://<project-ref>.supabase.co
SUPABASE_URL=https://<project-ref>.supabase.co

# Publishable (anon) key — client-side code; respects RLS policies.
# Dashboard → Project Settings → API → Project API keys → publishable / anon
SUPABASE_ANON_KEY=

# Secret (service-role) key — bypasses RLS; server-side only, never ship to browser.
# Dashboard → Project Settings → API → Project API keys → secret / service_role
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection — used by migrations, integration tests, raw SQL.
# Dashboard → Project Settings → Database → Connection string → URI.
# Substitute your DB password for [YOUR-PASSWORD]. If direct (IPv4) connections
# fail, use the Session pooler string instead.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres

# Reset-session tool — when "true", renders a floating button that clears the
# session + storage and returns to login (handy for re-running onboarding).
# Leave unset/false outside local testing. The VITE_ prefix is required so Vite
# exposes it to client code; the value is read at run (dev) and build time.
VITE_RESET_SESSION_TOOL=false
