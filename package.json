{
  "name": "nafios",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*",
    "tooling/*"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "check": "bun run typecheck && bun run test && bun run lint && bun run format:check",
    "typecheck": "bun --filter '*' typecheck",
    "test": "bun --filter '*' test",
    "lint": "biome lint .",
    "format": "biome check --write .",
    "format:check": "biome format ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
