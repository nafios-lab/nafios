{
  "name": "nafios",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*",
    "tooling/*"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "check": "bun run typecheck && bun run test && bun run lint && bun run format:check && bun run verify",
    "verify": "bun tooling/scripts/verify-workspace.ts",
    "typecheck": "bun --filter '*' typecheck",
    "test": "bun --filter '*' test",
    "lint": "biome lint .",
    "format": "biome check --write .",
    "format:check": "biome format .",
    "web:dev": "bun --filter '@nafios/web' dev",
    "web:build": "bun --filter '@nafios/web' build",
    "web:deploy:staging": "cd apps/web && bun run deploy:staging",
    "storybook:preview": "bun --filter '@nafios/storybook' preview",
    "docs:dev": "bun --filter '@nafios/docs' dev",
    "docs:build": "bun --filter '@nafios/docs' build",
    "docs:sync": "bun --filter '@nafios/docs' sync",
    "docs:preview": "bun --filter '@nafios/docs' preview",
    "test:integration": "bun test tests/integration/",
    "db:reset": "supabase db reset",
    "db:seed": "supabase db reset",
    "db:types": "supabase gen types typescript --local"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "^1.3.14",
    "supabase": "2.105.0",
    "typescript": "^6.0.3"
  }
}
